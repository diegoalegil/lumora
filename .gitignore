# Build artifacts
.build/
.swiftpm/
DerivedData/
*.xcodeproj/xcuserdata/
*.xcworkspace/xcuserdata/

# macOS
.DS_Store

# ──────────────────────────────────────────────────────────────────────────
# LICENSE FIREWALL — material that must NEVER enter this repo
# ──────────────────────────────────────────────────────────────────────────
# GPL reference material (linux-wallpaperengine, wallpaper-engine-mac) lives
# OUTSIDE the repo, under ~/we-refs. This entry is a belt-and-suspenders guard
# in case anyone checks it out inside the tree.
we-refs/
**/we-refs/

# Local Wallpaper Engine content (copyrighted Workshop wallpapers the user owns, used only as local test
# fixtures) must never be committed. Versioned here as a fail-closed guard so it holds on a fresh checkout,
# not only via a machine-local .git/info/exclude.
431960/
we-wallpapers/
**/431960/

# Parity corpus: FAIL-CLOSED. Ignore EVERYTHING under the corpus (copyrighted wallpaper pixels /
# assets / captured frames) and re-include ONLY the manifest + markdown docs. This avoids the
# allowlist-of-extensions trap where a new capture format (.mov/.gif/.heic/.tga/…) sneaks in.
parity/corpus/**
!parity/corpus/manifest.json
!parity/corpus/**/*.md
parity/captures/
parity/out/

# Built .app bundle (run Scripts/build_app.sh)
build/
